<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules (API >= 31). Backup is disabled app-wide via
   android:allowBackup="false", but we still exclude the auth-token DataStore from
   both cloud backup and device-to-device transfer so the JWT is never captured.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/settings.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/settings.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
