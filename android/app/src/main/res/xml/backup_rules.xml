<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup rules (API <= 30). Backup is disabled app-wide via
   android:allowBackup="false", but we still exclude the auth-token DataStore here
   so the JWT is never captured even if backup is later re-enabled.
-->
<full-backup-content>
    <exclude domain="file" path="datastore/settings.preferences_pb" />
</full-backup-content>
